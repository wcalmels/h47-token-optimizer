# Production — monetizable deployment
NODE_ENV=production
PORT=3001
APP_URL=https://api.tudominio.com

# Enable paid API (requires API keys on /api/*)
MONETIZATION_ENABLED=true

# Persistent billing data (API keys, usage, subscriptions)
DATA_DIR=/app/data

# Your first admin key — generate with: node scripts/create-api-key.mjs
BOOTSTRAP_API_KEY=h47_change_me_generate_a_real_key
BOOTSTRAP_PLAN=pro
BOOTSTRAP_EMAIL=you@example.com

# Secret to create keys via POST /api/keys
ADMIN_SECRET=change_me_long_random_string

# Rate limit per IP (requests/minute)
RATE_LIMIT=200
CORS_ORIGIN=https://tudominio.com

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
