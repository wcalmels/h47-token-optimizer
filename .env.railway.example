# Railway — trial deploy (copy each var to Railway dashboard)
# https://railway.app → Project → Variables

NODE_ENV=production
MONETIZATION_ENABLED=true
DATA_DIR=/app/data

# Set AFTER first deploy — Railway gives you a URL like https://xxx.up.railway.app
APP_URL=https://REPLACE-WITH-YOUR-RAILWAY-URL.up.railway.app

# Generate locally: npm run generate-secrets
BOOTSTRAP_API_KEY=
ADMIN_SECRET=
BOOTSTRAP_PLAN=pro
BOOTSTRAP_EMAIL=tu@email.com

RATE_LIMIT=300
CORS_ORIGIN=*

# Stripe TEST mode (optional for first trial — skip until you want payments)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
